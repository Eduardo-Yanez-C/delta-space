# Copie a `.env` y ajuste. No commitee secretos reales.
# ─── Entorno de ejecución ───
# NODE_ENV=development
# Puerto HTTP (Railway/Render inyectan PORT).
# PORT=4000

# ─── Base de datos (Prisma) ───
# API (apps/api): prisma/schema.prisma usa PostgreSQL. DATABASE_URL debe ser postgres:// o postgresql://
# (un file: aquí hace fallar prisma validate / arranque coherente del servidor API).
#
# Local con Docker (apps/api):
#   docker compose -f docker-compose.postgres.yml up -d
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/delta_space_dev?schema=public
#
# Supabase (pooler / directo según doc actual + sslmode si aplica):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
#
# Escritorio portable (solo empaquetado embed): SQLite en prisma/desktop/ — ver .env.desktop / docs DESKTOP_BACKEND_EMBEDDED.

# ─── Auth JWT ───
# Firma de sesiones API (obligatorio). En producción (NODE_ENV=production) el arranque falla si falta.
# JWT_SECRET=cambiar-por-secreto-largo-aleatorio

# Opcional: secretos HMAC adicionales (separados por coma), firmas aceptadas solo en el socket /conversations.
# JWT_TRUSTED_SECRETS=secreto_del_otro_pc

# ─── CORS / frontend ───
# Orígenes permitidos del navegador (coma-separados). Incluya la URL de Vercel (y previews si aplica).
# Preferido:
# WEB_ORIGIN=https://tu-app.vercel.app
# Compatibilidad histórica (mismo efecto si también se define):
# CORS_ORIGIN=https://tu-app.vercel.app,https://preview-xxx.vercel.app

# ─── Supabase (Storage y futuro Postgres) ───
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=  (solo servidor; nunca en el cliente)
# SUPABASE_STORAGE_BUCKET=delta-space-files
# Si el bucket es público y queréis URL pública en la respuesta de putObject: SUPABASE_STORAGE_PUBLIC_READ=1
# SUPABASE_STORAGE_PUBLIC_READ=0
# Almacenamiento: local (default) | supabase
# STORAGE_DRIVER=local
# Carpeta local cuando STORAGE_DRIVER=local (relativa al cwd del API)
# LOCAL_UPLOADS_DIR=uploads
#
# Archivos binarios (logo empresa, adjuntos chat, capturas FV) → ObjectStorageService (`STORAGE_DRIVER`).
# Migración one-shot disco → bucket (lee uploads/ local, no cambia STORAGE_DRIVER):
#   npm run migrate:uploads-to-supabase
#   DRY_RUN=1 npm run migrate:uploads-to-supabase

# ─── Escritorio / licencias (on-prem) ───
LICENSE_HMAC_SECRET=PVQ-DESKTOP-LICENSE-CHANGE-ME-IN-CI
# DESKTOP_LICENSE_DIAG_ALLOW=1
# DESKTOP_DEV_LICENSE_MAX_DAYS=30

# ─── SAM (suite agent) ───
# OPENAI_API_KEY=
# SUITE_AGENT_OPENAI_MODEL=gpt-4o-mini
