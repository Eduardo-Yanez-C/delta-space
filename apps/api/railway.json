{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": null,
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": [
      "/apps/api/**",
      "/Dockerfile.api",
      "/.dockerignore",
      "/package.json",
      "/package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": null,
    "preDeployCommand": "npm run prisma:deploy --workspace=api",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 120
  }
}
