# Copie a `.env.local` para desarrollo local. No commitee secretos.
# Vercel: definir las mismas variables en Project Settings → Environment Variables (solo las NEXT_PUBLIC_* van al bundle).

# URL base del API Nest (debe terminar en /api o sin barra final; se normaliza en código).
# Alias soportado: NEXT_PUBLIC_API_BASE_URL (preferido) o NEXT_PUBLIC_API_URL (histórico).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Origen del API para Socket.IO de conversaciones (opcional).
# En producción cloud NO debería ser localhost. Ej.: https://api.tu-dominio.com  (o el mismo host donde vive el /api)
# NEXT_PUBLIC_CONVERSATIONS_SOCKET_ORIGIN=http://localhost:4000

# Cliente Supabase solo en el navegador (cuando el front lea storage público o auth).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=delta-space-files
