{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": null,
    "dockerfilePath": "Dockerfile.web",
    "watchPatterns": [
      "/apps/web/**",
      "/Dockerfile.web",
      "/.dockerignore",
      "/package.json",
      "/package-lock.json"
    ]
  },
  "deploy": {
    "startCommand": null,
    "healthcheckPath": "/up",
    "healthcheckTimeout": 120
  }
}
