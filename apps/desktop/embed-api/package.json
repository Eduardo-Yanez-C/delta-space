{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "build": "prisma db push && prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "prisma db push && prisma generate && tsc -p tsconfig.build.json && node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "backfill:quote-main-items": "ts-node prisma/backfill-quote-main-items.ts",
    "backfill:product-technical-specs": "ts-node prisma/backfill-product-technical-specs.ts",
    "clean:test-data": "ts-node prisma/clean-test-data.ts",
    "clean:catalog": "ts-node prisma/clean-catalog.ts",
    "clean:templates": "ts-node prisma/clean-templates.ts",
    "clean:full-reset": "npx ts-node prisma/clean-full-reset.ts",
    "clean:seed-catalog-demo": "ts-node prisma/clean-seed-catalog-demo.ts",
    "clean:quotes-fv-clients-local": "ts-node prisma/clean-quotes-fv-studies-clients-local.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.0",
    "rimraf": "^5.0.0",
    "rxjs": "^7.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
